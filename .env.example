# Pick the provider you're using and set its key. The runner reads keys
# based on the `provider:` field in each run config in configs.yaml.
#
# Supported providers (all expose OpenAI-compatible /chat/completions):
#   openai       — platform.openai.com
#   openrouter   — openrouter.ai (free-tier friendly, used as default)
#   groq         — console.groq.com (free, phone-verified)
#   together     — together.ai

OPENROUTER_API_KEY=sk-or-v1-...

# Optional fallbacks if you swap providers in configs.yaml:
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
# TOGETHER_API_KEY=...
